{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "bash": "__STATE_DIR__/bin/copilot-usage-hook.sh sessionEnd",
        "timeoutSec": 10,
        "env": {
          "LLM_USAGE_POC_STATE_DIR": "__STATE_DIR__",
          "LLM_USAGE_POC_BIN_DIR": "__STATE_DIR__/bin"
        }
      }
    ]
  }
}
